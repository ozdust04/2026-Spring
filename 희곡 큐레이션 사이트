<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curating Plays | 공연기획자를 위한 희곡 플랫폼</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Pretendard:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Pretendard', sans-serif; }
        h1, h2, h3, .serif { font-family: 'Noto Serif KR', serif; }
        .play-card:hover { transform: translateY(-4px); transition: all 0.3s ease; }
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;  
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <h1 class="text-2xl font-bold tracking-tighter text-indigo-900">PLAY<span class="text-slate-500 italic">LIST</span></h1>
            <nav class="hidden md:flex space-x-8 text-sm font-medium">
                <a href="#" class="text-indigo-600 border-b-2 border-indigo-600 pb-1">희곡 검색</a>
                <a href="#" class="text-slate-500 hover:text-slate-800 transition">큐레이션 노트</a>
                <a href="#" class="text-slate-500 hover:text-slate-800 transition">라이센싱 안내</a>
            </nav>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col md:flex-row gap-8">
        
        <aside class="w-full md:w-64 space-y-6">
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h2 class="text-lg font-bold mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                    상세 필터
                </h2>
                
                <div class="mb-6">
                    <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-2">장르</label>
                    <select id="filter-genre" class="w-full bg-slate-50 border border-slate-200 rounded-md p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                        <option value="all">전체 장르</option>
                        <option value="정치">정치</option>
                        <option value="사회">사회</option>
                        <option value="가족">가족</option>
                        <option value="로맨스">로맨스</option>
                        <option value="코미디">코미디</option>
                        <option value="스릴러">스릴러</option>
                    </select>
                </div>

                <div class="mb-6">
                    <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-2">총 인원</label>
                    <select id="filter-cast" class="w-full bg-slate-50 border border-slate-200 rounded-md p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                        <option value="all">제한 없음</option>
                        <option value="2">2인극</option>
                        <option value="3-5">3인 - 5인</option>
                        <option value="6">6인 이상</option>
                    </select>
                </div>

                <div class="mb-6">
                    <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-2">무대 규모</label>
                    <div class="space-y-2">
                        <label class="flex items-center text-sm cursor-pointer">
                            <input type="checkbox" name="stage" value="소극장" class="mr-2 rounded text-indigo-600"> 소극장
                        </label>
                        <label class="flex items-center text-sm cursor-pointer">
                            <input type="checkbox" name="stage" value="중극장" class="mr-2 rounded text-indigo-600"> 중극장
                        </label>
                        <label class="flex items-center text-sm cursor-pointer">
                            <input type="checkbox" name="stage" value="대극장" class="mr-2 rounded text-indigo-600"> 대극장
                        </label>
                    </div>
                </div>

                <button onclick="applyFilters()" class="w-full bg-indigo-900 text-white py-2 rounded-md font-semibold text-sm hover:bg-indigo-800 transition shadow-lg">필터 적용</button>
            </div>
        </aside>

        <main class="flex-1">
            <div class="flex justify-between items-end mb-6">
                <div>
                    <h2 class="text-3xl font-bold serif">추천 희곡 라이브러리</h2>
                    <p class="text-slate-500 mt-1">현재 프로덕션 조건에 맞는 최적의 텍스트를 찾아보세요.</p>
                </div>
                <p class="text-sm text-slate-400"><span id="result-count" class="font-bold text-indigo-600">0</span>개의 작품 검색됨</p>
            </div>

            <div id="play-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                </div>
        </main>
    </div>

    <div id="modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-2xl shadow-2xl relative">
            <button onclick="closeModal()" class="absolute top-4 right-4 p-2 hover:bg-slate-100 rounded-full transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <div id="modal-content" class="p-8">
                </div>
        </div>
    </div>

    <script>
        const plays = [
            {
                id: 1,
                title: "스카이라이트",
                originalTitle: "Skylight",
                author: "데이비드 헤어 (David Hare)",
                genre: "로맨스, 정치",
                awards: ["토니상 최우수 작품상", "올리비에상 최우수 신작상"],
                castCount: 3,
                castInfo: "남성 2, 여성 1",
                ageRange: "20대 - 50대",
                stageSize: "소극장",
                translation: "출판됨 (국내 다수 공연)",
                licenseStatus: "Contact Agency",
                domesticAgency: "비떵르(SAC) 또는 에이전시 문의",
                foreignLink: "https://www.concordtheatricals.com/p/2115/skylight",
                summary: "가치관의 차이로 헤어졌던 옛 연인이 재회하며 벌어지는 치열한 설전. 개인의 성공과 사회적 책임에 대한 날카로운 통찰을 담았습니다.",
                analysis: "이 작품은 단순히 옛 연인의 재회를 넘어 90년대 영국 사회의 계급 갈등을 내면화하고 있습니다. 미니멀한 무대 구성이 가능하며 배우들의 대사 처리 속도와 호흡이 프로덕션의 핵심입니다."
            },
            {
                id: 2,
                title: "피치포크 디즈니",
                originalTitle: "The Pitchfork Disney",
                author: "필립 리들리 (Philip Ridley)",
                genre: "스릴러",
                awards: ["이브닝 스탠다드상 신인상"],
                castCount: 4,
                castInfo: "남성 3, 여성 1",
                ageRange: "20대 - 30대",
                stageSize: "소극장",
                translation: "공연됨 (미출판)",
                licenseStatus: "Available",
                domesticAgency: "해외 직계약 가능",
                foreignLink: "https://www.nickhernbooks.co.uk/the-pitchfork-disney",
                summary: "현대 영국 연극의 'In-Yer-Face' 경향을 선도한 작품. 고립된 아파트에서 초콜릿을 먹으며 살아가는 쌍둥이 남매에게 낯선 방문자가 찾아옵니다.",
                analysis: "그로테스크한 이미지와 공포를 시각화하는 능력이 중요합니다. 소극장의 밀폐된 공간감을 극대화할 수 있는 연출적 상상력이 요구되는 텍스트입니다."
            },
            {
                id: 3,
                title: "디 얼라이",
                originalTitle: "The Ally",
                author: "이타마르 모세 (Itamar Moses)",
                genre: "정치, 사회",
                awards: ["2024 루실 로텔상 노미네이트"],
                castCount: 7,
                castInfo: "남성 4, 여성 3 (다양한 인종)",
                ageRange: "20대 - 40대",
                stageSize: "중극장",
                translation: "미출판",
                licenseStatus: "Restricted",
                domesticAgency: "해외 에이전시 승인 필요",
                foreignLink: "https://www.theconcord.com",
                summary: "대학 교수가 제자의 청원에 서명하면서 시작되는 이스라엘-팔레스타인 갈등과 학내 정치의 복잡한 층위.",
                analysis: "최신 담론을 다루는 작품으로, 대사량이 매우 방대합니다. 정치적 올바름과 지적인 논쟁을 무대화하고 싶은 프로덕션에 추천합니다."
            },
            {
                id: 4,
                title: "안 이벤션",
                originalTitle: "An Intervention",
                author: "마이크 바틀렛 (Mike Bartlett)",
                genre: "사회, 코미디",
                awards: ["올리비에상 수상 작가"],
                castCount: 2,
                castInfo: "성별 무관 (2인)",
                ageRange: "30대",
                stageSize: "소극장",
                translation: "공연됨",
                licenseStatus: "Available",
                domesticAgency: "에이전시 대행 가능",
                foreignLink: "https://www.nickhernbooks.co.uk/an-intervention",
                summary: "정부의 해외 군사 개입을 두고 갈등하는 두 친구. 개인의 우정과 국가의 폭력은 어떻게 연결되는가?",
                analysis: "성별에 구애받지 않는 캐스팅이 큰 장점입니다. 배우의 연기력에 전적으로 의존하는 구조이며, 대사 리듬감이 매우 뛰어난 번역이 필수적입니다."
            },
            {
                id: 5,
                title: "오슬로",
                originalTitle: "Oslo",
                author: "J.T. 로저스 (J.T. Rogers)",
                genre: "정치, 역사",
                awards: ["토니상 최우수 작품상", "오비상"],
                castCount: 14,
                castInfo: "남성 12, 여성 2",
                ageRange: "30대 - 60대",
                stageSize: "대극장",
                translation: "출판됨",
                licenseStatus: "Contact Agency",
                domesticAgency: "에이전시 대행 필수",
                foreignLink: "https://www.concordtheatricals.com/p/62263/oslo",
                summary: "1993년 오슬로 협정을 끌어내기 위한 노르웨이 외교관 부부의 숨겨진 비하인드 스토리.",
                analysis: "방대한 캐스팅과 역동적인 무대 전환이 필요한 대작입니다. 전문 기획 단계에서 정치적 앙상블 극을 고민한다면 최적의 선택지입니다."
            }
        ];

        function renderCards(filteredPlays) {
            const grid = document.getElementById('play-grid');
            const count = document.getElementById('result-count');
            grid.innerHTML = '';
            count.innerText = filteredPlays.length;

            filteredPlays.forEach(play => {
                const card = document.createElement('div');
                card.className = "play-card bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm cursor-pointer";
                card.onclick = () => openModal(play);
                
                card.innerHTML = `
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-xs font-bold text-indigo-600 bg-indigo-50 px-2 py-1 rounded uppercase">${play.genre}</span>
                            <span class="text-xs text-slate-400 font-medium">${play.stageSize}</span>
                        </div>
                        <h3 class="text-xl font-bold mb-1">${play.title}</h3>
                        <p class="text-sm text-slate-500 mb-4">${play.originalTitle} | ${play.author}</p>
                        <p class="text-sm text-slate-600 line-clamp-3 mb-4">${play.summary}</p>
                        <div class="flex flex-wrap gap-2 mb-4">
                            ${play.awards.map(award => `<span class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded-full font-bold">🏆 ${award}</span>`).join('')}
                        </div>
                        <div class="pt-4 border-t border-slate-100 flex justify-between items-center text-xs font-bold text-slate-400 uppercase">
                            <span>Cast: ${play.castCount}인</span>
                            <span class="${play.licenseStatus === 'Available' ? 'text-green-600' : 'text-amber-600'}">${play.licenseStatus}</span>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function openModal(play) {
            const modal = document.getElementById('modal');
            const content = document.getElementById('modal-content');
            
            content.innerHTML = `
                <div class="mb-6">
                    <span class="text-indigo-600 font-bold text-sm">${play.genre}</span>
                    <h2 class="text-3xl font-bold serif mt-1">${play.title}</h2>
                    <p class="text-slate-500">${play.originalTitle} | ${play.author}</p>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="bg-slate-50 p-4 rounded-lg">
                        <p class="text-[10px] text-slate-400 font-bold uppercase mb-1">캐스팅 정보</p>
                        <p class="text-sm font-semibold">${play.castInfo} (${play.ageRange})</p>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-lg">
                        <p class="text-[10px] text-slate-400 font-bold uppercase mb-1">번역 상태</p>
                        <p class="text-sm font-semibold">${play.translation}</p>
                    </div>
                </div>

                <div class="mb-8">
                    <h4 class="font-bold mb-2 flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg> 줄거리</h4>
                    <p class="text-slate-600 leading-relaxed text-sm">${play.summary}</p>
                </div>

                <div class="mb-8 p-5 bg-indigo-50 border-l-4 border-indigo-500 rounded-r-lg">
                    <h4 class="font-bold text-indigo-900 mb-2 flex items-center italic">Dramaturg's Note</h4>
                    <p class="text-slate-700 text-sm leading-relaxed">${play.analysis}</p>
                </div>

                <div class="space-y-3">
                    <a href="${play.foreignLink}" target="_blank" class="block w-full text-center bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-black transition">해외 라이센싱 사이트 이동 (원문)</a>
                    <button class="block w-full text-center bg-white border border-slate-300 text-slate-700 py-3 rounded-xl font-bold hover:bg-slate-50 transition">국내 대행사 정보: ${play.domesticAgency}</button>
                </div>
            `;
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('modal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function applyFilters() {
            const genre = document.getElementById('filter-genre').value;
            const cast = document.getElementById('filter-cast').value;
            const selectedStages = Array.from(document.querySelectorAll('input[name="stage"]:checked')).map(cb => cb.value);

            const filtered = plays.filter(play => {
                const genreMatch = genre === 'all' || play.genre.includes(genre);
                
                let castMatch = true;
                if (cast === '2') castMatch = play.castCount === 2;
                else if (cast === '3-5') castMatch = play.castCount >= 3 && play.castCount <= 5;
                else if (cast === '6') castMatch = play.castCount >= 6;

                const stageMatch = selectedStages.length === 0 || selectedStages.includes(play.stageSize);

                return genreMatch && castMatch && stageMatch;
            });

            renderCards(filtered);
        }

        // Initial Render
        renderCards(plays);
    </script>
</body>
</html>
